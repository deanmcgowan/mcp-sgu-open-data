# ============================================================
# SGU Brunnar MCP Server — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.
# ============================================================

# ----------------------------------------------------------
# Required secrets
# ----------------------------------------------------------

# Authorization token that MCP clients must present in the Authorization header.
# Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_BEARER_TOKEN=change-me-before-use

# Secret for opaque, signed continuation tokens. Use a distinct random value.
MCP_CONTINUATION_SECRET=change-me-before-use

# Google Maps / Geocoding API key.
# Create at: https://console.cloud.google.com/apis/credentials
# Enable "Geocoding API" for the key.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ----------------------------------------------------------
# SGU API
# ----------------------------------------------------------

# Base URL of the SGU OGC API Features endpoint.
SGU_BASE_URL=https://api.sgu.se/oppnadata/brunnar/ogc/features/v1

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------

# Runtime environment: development | staging | production
APP_ENV=development

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ----------------------------------------------------------
# Limits
# ----------------------------------------------------------

# Maximum number of records returned inline in a single MCP tool response.
MAX_INLINE_RESULTS=100

# Maximum number of records in a single export (CSV or GeoJSON).
MAX_EXPORT_RECORDS=50000

# Maximum number of concurrent upstream SGU requests.
MAX_UPSTREAM_CONCURRENCY=4

# Cache TTL in seconds for metadata and query results.
CACHE_TTL_SECONDS=300

# TTL in seconds before an export file is deleted.
EXPORT_TTL_SECONDS=3600

# ----------------------------------------------------------
# Server (optional, defaults shown)
# ----------------------------------------------------------

# Host and port for local development.
# Cloud Run uses the PORT environment variable automatically.
# HOST=0.0.0.0
# PORT=8080
